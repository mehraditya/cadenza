<mujoco model="cadenza_base">
  <!--
    Plain base scene: flat ground, sky, lights. No robot, no obstacles.
    Use as a sandbox (Sim(xml_path=...)) or as the foundation a Scene
    builds on. Shipped in the wheel — has no external mesh references.
  -->
  <compiler angle="radian" autolimits="true"/>
  <option gravity="0 0 -9.81" timestep="0.002" iterations="50" tolerance="1e-10"
          cone="elliptic" impratio="100"/>

  <default>
    <geom contype="1" conaffinity="1" condim="3"
          friction="0.6 0.02 0.001" solref="0.005 1" solimp="0.98 0.99 0.001"/>
  </default>

  <asset>
    <texture name="sky" type="skybox" builtin="gradient"
             rgb1="0.45 0.60 0.85" rgb2="0.75 0.85 0.95"
             width="512" height="512" mark="random" markrgb="1 1 1"
             random="0.01"/>
    <texture name="ground_tex" type="2d" builtin="flat"
             rgb1="0.72 0.70 0.66" rgb2="0.68 0.66 0.62"
             width="512" height="512" mark="random" markrgb="0.65 0.63 0.60"
             random="0.05"/>
    <material name="floor_mat" texture="ground_tex" texrepeat="12 12"
              texuniform="true" reflectance="0.02" rgba="0.75 0.73 0.70 1"/>
  </asset>

  <worldbody>
    <light name="sun"     pos="5 3 12"   dir="-0.3 -0.2 -1"
           diffuse="1.2 1.15 1.0" specular="0.5 0.5 0.4" castshadow="true"/>
    <light name="ambient" pos="0 0 10"   dir="0 0 -1"
           diffuse="0.35 0.38 0.45" specular="0 0 0" castshadow="false"/>
    <light name="fill"    pos="-5 -3 6"  dir="0.3 0.2 -1"
           diffuse="0.25 0.25 0.30" castshadow="false"/>

    <geom name="floor" type="plane" size="30 30 0.1" material="floor_mat"
          condim="6" friction="0.8 0.02 0.01"/>
  </worldbody>
</mujoco>
